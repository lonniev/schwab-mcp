# =============================================================================
# schwab-mcp v0.3.0 — Environment Variables for Horizon Deployment
# =============================================================================
# Copy this file to .env and fill in your values.
# All values are loaded by pydantic-settings (settings.py).

# Schwab Trader API base URL (default: https://api.schwabapi.com)
# Override if Schwab changes their endpoint or for proxy/staging use.
SCHWAB_TRADER_API=https://api.schwabapi.com

# NOTE: Schwab OAuth app credentials (client_id / client_secret) are delivered
# by the operator via Secure Courier (service="schwab-operator"), not env vars.

# -----------------------------------------------------------------------------
# Secure Courier — Nostr DM credential exchange (required)
# -----------------------------------------------------------------------------
# Generate with: nak key generate
# The nsec stays here; the npub is derived automatically for registry lookup.
TOLLBOOTH_NOSTR_OPERATOR_NSEC=nsec1...
TOLLBOOTH_NOSTR_RELAYS=wss://nostr.wine,wss://relay.primal.net

# -----------------------------------------------------------------------------
# NeonVault — ledger + credential persistence (required)
# -----------------------------------------------------------------------------
# Serverless Postgres (Neon, Supabase, etc.)
NEON_DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# BTCPay Server — Lightning invoices (required for credits)
# -----------------------------------------------------------------------------
BTCPAY_HOST=https://btcpay.example.com
BTCPAY_STORE_ID=
BTCPAY_API_KEY=

# -----------------------------------------------------------------------------
# Credit tuning (optional)
# -----------------------------------------------------------------------------
# Free starter credits for new users (0 = disabled)
# SEED_BALANCE_SATS=100

# Credit expiration in seconds (default: 604800 = 7 days)
# CREDIT_TTL_SECONDS=604800

# DPYC registry cache TTL in seconds (default: 300)
# DPYC_REGISTRY_CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Tier pricing (optional)
# -----------------------------------------------------------------------------
# JSON mapping tier names to credit multipliers
# BTCPAY_TIER_CONFIG={"vip": {"multiplier": 100000}}

# JSON mapping patron npubs to tier names
# BTCPAY_USER_TIERS={"npub1abc...": "vip"}

# -----------------------------------------------------------------------------
# OAuth redirect URI — NOT an env var.
#
# The wheel resolves the OAuth callback URL at runtime via
# resolve_service_by_name("tollbooth-oauth2-callback") against the
# dpyc-community registry. There is no SCHWAB_OAUTH_REDIRECT_URI env
# var in the current code path — setting one has no effect. Use the
# community registry to change it; coordinate the change with whatever
# URL is registered as a Callback URL in the Schwab developer portal,
# since Schwab does byte-for-byte matching on redirect_uri.
# -----------------------------------------------------------------------------
